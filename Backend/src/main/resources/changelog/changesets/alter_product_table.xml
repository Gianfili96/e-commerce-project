<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet id="20260414-01" author="academy">
        <addColumn tableName="product_entity">
            <column name="title" type="VARCHAR(255)"/>
            <column name="des" type="VARCHAR(255)"/>
            <column name="oldPrice" type="INT"/>
            <column name="price" type="INT"/>
            <column name="brand" type="VARCHAR(255)"/>
            <column name="image" type="VARCHAR(255)"/>
            <column name="isNew" type="BOOLEAN"/>
            <column name="category" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260414-02" author="academy">
        <dropColumn tableName="product_entity">
            <column name="id"/>
            <column name="name"/>
        </dropColumn>
    </changeSet>
    <changeSet id="20260415-01" author="academy">
        <renameColumn tableName="product_entity" oldColumnName="isNew" newColumnName="is_new" columnDataType="BOOLEAN" />
        <renameColumn tableName="product_entity" oldColumnName="oldPrice" newColumnName="old_price" columnDataType="INT"/>
    </changeSet>
    <changeSet id="20260415-02" author="academy">
        <addColumn tableName="product_entity">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20260416-01" author="academy">
        <renameColumn tableName="product_entity"
                      oldColumnName="image"
                      newColumnName="image_url"
                      columnDataType="VARCHAR(255)"/>
    </changeSet>
    <changeSet id="20260421-10" author="academy">
        <addColumn tableName="product_entity">
            <column name="deactivated" type="BOOLEAN"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>