    <changeSet author="academy" id="1776848870989-1">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="cart_entity"/></not>
        </preConditions>
        <createTable tableName="cart_entity">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="cart_entityPK"/>
            </column>
            <column name="created_at" type="datetime(6)"/>
            <column name="quantity" type="INT"/>
            <column name="order_id" type="BIGINT"/>
            <column name="product_id" type="BIGINT"/>
        </createTable>
    </changeSet>

    <changeSet author="academy" id="1776848870989-2">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="category_entity"/></not>
        </preConditions>
